{
  "schema_version": 1,
  "enabled": false,
  "engine_weight": 0.55,
  "council_weight": 0.45,
  "rounds": 2,
  "minimum_valid_agents": 3,
  "timeout_seconds": 120,
  "max_attempts": 2,
  "agents": [
