{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tournament-forecaster/results.import.schema.json",
  "title": "Tournament Forecaster local results import",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "provider", "retrieved_at", "results"],
  "properties": {
    "schema_version": {"const": 1},
    "provider": {"type": "string", "minLength": 1},
    "retrieved_at": {"type": "string", "format": "date-time"},
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "stage_id", "home_team", "away_team", "home_score", "away_score"],
        "properties": {
          "status": {"const": "final"},
          "match_id": {"type": "string", "minLength": 1},
          "stage_id": {"type": "string", "minLength": 1},
          "home_team": {"type": "string", "minLength": 1},
          "away_team": {"type": "string", "minLength": 1},
          "home_score": {"type": "integer", "minimum": 0},
          "away_score": {"type": "integer", "minimum": 0},
          "leg": {"type": "integer", "minimum": 1, "default": 1},
          "winner_team": {"type": "string", "minLength": 1},
          "source_id": {"type": "string", "minLength": 1},
          "metadata": {"type": "object"}
        }
      }
    }
  }
}
