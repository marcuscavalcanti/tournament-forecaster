{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tournament-forecaster.example/schemas/forecast.schema.json",
  "title": "Tournament Forecaster forecast artifact",
  "$defs": {
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "output_key": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
    },
    "probability": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "matchup": {
      "type": "object",
      "required": ["stage_id", "opponent_team_id", "probability"],
      "properties": {
        "stage_id": {"$ref": "#/$defs/stable_id"},
        "opponent_team_id": {"$ref": "#/$defs/stable_id"},
        "probability": {"$ref": "#/$defs/probability"}
      },
      "additionalProperties": false
    },
    "confidence_interval": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/probability"}
    },
    "provenance": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "source_id": {"$ref": "#/$defs/stable_id"},
        "uri": {"type": "string", "minLength": 1},
        "retrieved_at": {"type": "string", "minLength": 1},
        "metadata": {"$ref": "#/$defs/metadata"}
      },
      "additionalProperties": false
    },
    "council_opinion": {
      "type": "object",
      "required": [
        "agent_id",
        "round",
        "stage_probabilities",
        "championship_probability",
        "confidence",
        "summary",
        "key_factors"
      ],
      "properties": {
        "agent_id": {"$ref": "#/$defs/stable_id"},
        "round": {"type": "integer", "minimum": 1, "maximum": 3},
        "stage_probabilities": {
          "type": "object",
          "propertyNames": {"$ref": "#/$defs/stable_id"},
          "additionalProperties": {"$ref": "#/$defs/probability"}
        },
        "championship_probability": {"$ref": "#/$defs/probability"},
        "confidence": {"$ref": "#/$defs/probability"},
        "summary": {"type": "string", "minLength": 1},
        "key_factors": {
          "type": "array",
          "maxItems": 12,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "council_failure": {
      "type": "object",
      "required": ["agent_id", "category", "detail"],
      "properties": {
        "agent_id": {"$ref": "#/$defs/stable_id"},
        "category": {"type": "string", "minLength": 1},
        "detail": {"type": "string", "minLength": 1, "maxLength": 600}
      },
      "additionalProperties": false
    },
    "council_round": {
      "type": "object",
      "required": ["round", "opinions", "failures"],
      "properties": {
        "round": {"type": "integer", "minimum": 1, "maximum": 3},
        "opinions": {
          "type": "array",
          "items": {"$ref": "#/$defs/council_opinion"}
        },
        "failures": {
          "type": "array",
          "items": {"$ref": "#/$defs/council_failure"}
        }
      },
      "additionalProperties": false
    },
    "council_participant": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "provider",
        "model",
        "reasoning_effort",
        "thinking_budget_tokens",
        "max_output_tokens"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/stable_id"},
        "display_name": {"type": "string", "minLength": 1},
        "provider": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "reasoning_effort": {
          "oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]
        },
        "thinking_budget_tokens": {
          "oneOf": [{"type": "integer", "minimum": 1}, {"type": "null"}]
        },
        "max_output_tokens": {"type": "integer", "minimum": 128}
      },
      "additionalProperties": false
    },
    "council_baseline": {
      "type": "object",
      "required": ["stage_probabilities", "championship_probability"],
      "properties": {
        "stage_probabilities": {
          "type": "object",
          "propertyNames": {"$ref": "#/$defs/stable_id"},
          "additionalProperties": {"$ref": "#/$defs/probability"}
        },
        "championship_probability": {"$ref": "#/$defs/probability"}
      },
      "additionalProperties": false
    },
    "disabled_council": {
      "type": "object",
      "required": ["enabled"],
      "properties": {"enabled": {"const": false}},
      "additionalProperties": false
    },
    "council": {
      "type": "object",
      "required": [
        "status",
        "reason",
        "engine_weight",
        "council_weight",
        "rounds_configured",
        "rounds_completed",
        "minimum_valid_agents",
        "participants",
        "engine_baseline",
        "consensus",
        "rounds",
        "matchup_probabilities_basis",
        "uncertainty_basis"
      ],
      "properties": {
        "status": {"enum": ["applied", "fallback", "disabled"]},
        "reason": {
          "oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]
        },
        "engine_weight": {"$ref": "#/$defs/probability"},
        "council_weight": {"$ref": "#/$defs/probability"},
        "rounds_configured": {"type": "integer", "minimum": 1, "maximum": 3},
        "rounds_completed": {"type": "integer", "minimum": 0, "maximum": 3},
        "minimum_valid_agents": {"type": "integer", "minimum": 1},
        "participants": {
          "type": "array",
          "items": {"$ref": "#/$defs/council_participant"}
        },
        "engine_baseline": {"$ref": "#/$defs/council_baseline"},
        "consensus": {
          "oneOf": [{"$ref": "#/$defs/council_opinion"}, {"type": "null"}]
        },
        "rounds": {
          "type": "array",
          "items": {"$ref": "#/$defs/council_round"}
        },
        "matchup_probabilities_basis": {"const": "engine_only"},
        "uncertainty_basis": {
          "const": "engine_sampling_with_fixed_council_consensus"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "applied"}}},
          "then": {"properties": {"consensus": {"$ref": "#/$defs/council_opinion"}}}
        }
      ]
    },
    "simulation": {
      "type": "object",
      "required": ["seed", "iterations", "confidence_level"],
      "properties": {
        "seed": {"type": "integer", "minimum": 0},
        "iterations": {"type": "integer", "minimum": 1},
        "confidence_level": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1}
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "tournament_id",
    "focus_team_id",
    "stage_probabilities",
    "matchup_probabilities",
    "championship_probability",
    "confidence_intervals",
    "input_provenance",
    "warnings",
    "council"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "run_id": {"$ref": "#/$defs/stable_id"},
    "generated_at": {"type": "string", "minLength": 1},
    "tournament_id": {"$ref": "#/$defs/stable_id"},
    "focus_team_id": {"$ref": "#/$defs/stable_id"},
    "stage_probabilities": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/stable_id"},
      "additionalProperties": {"$ref": "#/$defs/probability"}
    },
    "stage_order": {
      "description": "Explicit stage order. Schema-v2 readers fall back to stage_probabilities property insertion order when omitted.",
      "type": "array",
      "items": {"$ref": "#/$defs/stable_id"},
      "uniqueItems": true
    },
    "matchup_probabilities": {
      "type": "array",
      "items": {"$ref": "#/$defs/matchup"}
    },
    "championship_probability": {"$ref": "#/$defs/probability"},
    "confidence_intervals": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/output_key"},
      "additionalProperties": {"$ref": "#/$defs/confidence_interval"}
    },
    "input_provenance": {
      "type": "array",
      "items": {"$ref": "#/$defs/provenance"}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "council": {
      "oneOf": [
        {"$ref": "#/$defs/council"},
        {"$ref": "#/$defs/disabled_council"},
        {"type": "null"}
      ]
    },
    "tournament_display_name": {"type": "string", "minLength": 1},
    "team_display_names": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/stable_id"},
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "simulation": {"$ref": "#/$defs/simulation"}
  },
  "additionalProperties": false
}
